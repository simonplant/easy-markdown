build_context() {
    local agent_role="${AGENT_CONTEXT_ROLE:-developer}"
    local context=""
    for arg in "$@"; do
        [[ -n "$context" ]] && context="$context $arg" || context="$arg"
    done
    # Developer/architect need CLAUDE.md; validator/groom agents don't benefit enough to justify tokens
    if [[ "$agent_role" == "developer" || "$agent_role" == "architect" ]]; then
        local claude_md
        claude_md=$(find_claude_md)
        [[ -n "$claude_md" ]] && context="$context @$claude_md"
    fi
    # Only developer/architect need ARCHITECTURE.md/PRODUCT.md
    if [[ "$agent_role" == "developer" || "$agent_role" == "architect" ]]; then
        local project_docs
        project_docs=$(find_project_docs)
        [[ -n "$project_docs" ]] && context="$context $project_docs"
    fi
    printf '%s\n' "$context"
}

