# A self-contained sprint orchestration tool for Claude Code
#
# Usage: .aishore/aishore <command> [options]
#
# Commands:
#   auto <scope>    Autonomous mode — drain backlog (done, p0, p1, p2)
#   run [count|ID]  Run sprints (default: 1, feature branches, auto-commit)
#   groom           Groom bugs/tech debt (Tech Lead)
#   groom --backlog Groom features (Product Owner)
#   review          Architecture review
#   metrics         Show sprint metrics
#   update          Update aishore from upstream (with checksum verification)
#   checksums       Regenerate checksums.sha256
#   diagnose        Show extended diagnostics from last sprint failure
#   init            Setup wizard (prerequisites, config, backlog)
#   help            Show this help

set -euo pipefail

AISHORE_TMPDIR=""
AISHORE_DID_STASH=""
AISHORE_BASE_BRANCH=""
AISHORE_FEATURE_BRANCH=""
AISHORE_WORKTREE_DIR=""
LAST_AGENT_LOG=""
cleanup_exit() {
    # Clean up worktree on unexpected exit
    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        cd "$PROJECT_ROOT" 2>/dev/null || true
        git worktree remove "$AISHORE_WORKTREE_DIR" --force 2>/dev/null || true
        [[ -d "$AISHORE_WORKTREE_DIR" ]] && rm -rf "$AISHORE_WORKTREE_DIR" 2>/dev/null || true
        [[ -n "$AISHORE_FEATURE_BRANCH" ]] && git branch -D "$AISHORE_FEATURE_BRANCH" >/dev/null 2>&1 || true
        AISHORE_WORKTREE_DIR=""
        AISHORE_FEATURE_BRANCH=""
    elif [[ -n "$AISHORE_FEATURE_BRANCH" && -n "$AISHORE_BASE_BRANCH" ]]; then
        # Clean up feature branch on unexpected exit (stash mode)
        git checkout "$AISHORE_BASE_BRANCH" >/dev/null 2>&1 || true
        git branch -D "$AISHORE_FEATURE_BRANCH" >/dev/null 2>&1 || true
        AISHORE_FEATURE_BRANCH=""
    fi
    # Restore stashed changes on unexpected exit
    if [[ "$AISHORE_DID_STASH" == "true" ]]; then
        AISHORE_DID_STASH=""
        restore_stash || true
    fi
    [[ -n "$AISHORE_TMPDIR" && -d "$AISHORE_TMPDIR" ]] && rm -rf "$AISHORE_TMPDIR"
    return 0
}
trap cleanup_exit EXIT

ensure_tmpdir() {
    [[ -z "$AISHORE_TMPDIR" ]] && AISHORE_TMPDIR=$(mktemp -d "${TMPDIR:-/tmp}/aishore.XXXXXX")
    printf '%s\n' "$AISHORE_TMPDIR"
}

reverse_lines() {
    if command -v tac &>/dev/null; then
        tac
    else
        awk '{lines[NR]=$0} END{for(i=NR;i>=1;i--) print lines[i]}'
    fi
}

