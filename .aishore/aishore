load_config() {
    # Only load if config exists
    [[ ! -f "$CONFIG_FILE" ]] && { _apply_env_overrides; return 0; }

    if command -v yq &> /dev/null; then
        local -a _cfg_map=(
            ".validation.command    VALIDATE_CMD"
            ".validation.timeout    VALIDATE_TIMEOUT"
            ".fix.command           FIX_CMD"
            ".models.primary        MODEL_PRIMARY"
            ".models.fast           MODEL_FAST"
            ".agent.timeout         AGENT_TIMEOUT"
            ".notifications.on_complete NOTIFY_CMD"
            ".auto.groom_threshold  AUTO_GROOM_THRESHOLD"
            ".auto.max_failures     AUTO_MAX_FAILURES"
            ".groom.max_items       GROOM_MAX_ITEMS"
            ".groom.min_priority    GROOM_MIN_PRIORITY"
            ".scope.mode            SCOPE_MODE"
            ".maturity.enabled      MATURITY_ENABLED"
            ".streaming.enabled    STREAMING_ENABLED"
            ".streaming.max_lines  STREAMING_MAX_LINES"
            ".output.truncate_lines OUTPUT_TRUNCATE_LINES"
            ".merge.strategy        MERGE_STRATEGY"
            ".pr.create             CREATE_PR"
            ".isolation.mode        ISOLATION_MODE"
            ".notifications.system NOTIFY_SYSTEM"
            ".permissions.developer CFG_PERMS_DEVELOPER"
            ".permissions.validator CFG_PERMS_VALIDATOR"
            ".permissions.reviewer  CFG_PERMS_REVIEWER"
        )
        local cfg_val _key _var
        for _entry in "${_cfg_map[@]}"; do
            read -r _key _var <<< "$_entry"
            cfg_val=$(yq -r "$_key // \"\"" "$CONFIG_FILE" 2>/dev/null) || cfg_val=""
            [[ -n "$cfg_val" ]] && printf -v "$_var" '%s' "$cfg_val"
        done
    else
        # Simple grep fallback for validation command only
        local cfg_cmd
        cfg_cmd=$(grep -E '^\s*command:' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*command:\s*//' | tr -d '"' || echo "")
        [[ -n "$cfg_cmd" ]] && VALIDATE_CMD="$cfg_cmd"
        # Always warn when config.yaml has content but yq is unavailable
        if grep -qE '[^[:space:]]' "$CONFIG_FILE" 2>/dev/null; then
            log_warning "config.yaml exists but yq is not installed — most settings in ${CONFIG_FILE} are being ignored (only validation.command is read via fallback). yq is a lightweight YAML processor. Install it for full config support: https://github.com/mikefarah/yq#install"
        fi
    fi

    # Read backlog_files list if present (yq path only)
    if command -v yq &> /dev/null; then
        local bf_count
        bf_count=$(yq -r '.backlog_files // [] | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
        if [[ "$bf_count" -gt 0 ]]; then
            BACKLOG_FILES=()
            local _bf_entry
            while IFS= read -r _bf_entry; do
                [[ -n "$_bf_entry" ]] && BACKLOG_FILES+=("$_bf_entry")
            done < <(yq -r '.backlog_files[]' "$CONFIG_FILE" 2>/dev/null)
        fi
    fi

    # Env vars always win last
    _apply_env_overrides

    # Validate declared backlog files exist
    _validate_backlog_files

    return 0
}

_apply_env_overrides() {
    local -a _env_map=(
        "AISHORE_MODEL_PRIMARY      MODEL_PRIMARY"
        "AISHORE_MODEL_FAST         MODEL_FAST"
        "AISHORE_AGENT_TIMEOUT      AGENT_TIMEOUT"
        "AISHORE_VALIDATE_CMD       VALIDATE_CMD"
        "AISHORE_VALIDATE_TIMEOUT   VALIDATE_TIMEOUT"
        "AISHORE_FIX_CMD            FIX_CMD"
        "AISHORE_NOTIFY_CMD         NOTIFY_CMD"
        "AISHORE_AUTO_GROOM_THRESHOLD AUTO_GROOM_THRESHOLD"
        "AISHORE_AUTO_MAX_FAILURES  AUTO_MAX_FAILURES"
        "AISHORE_GROOM_MAX_ITEMS    GROOM_MAX_ITEMS"
        "AISHORE_GROOM_MIN_PRIORITY GROOM_MIN_PRIORITY"
        "AISHORE_SCOPE_MODE        SCOPE_MODE"
        "AISHORE_MATURITY          MATURITY_ENABLED"
        "AISHORE_STREAMING         STREAMING_ENABLED"
        "AISHORE_STREAMING_MAX_LINES STREAMING_MAX_LINES"
        "AISHORE_OUTPUT_TRUNCATE_LINES OUTPUT_TRUNCATE_LINES"
        "AISHORE_MERGE_STRATEGY    MERGE_STRATEGY"
        "AISHORE_CREATE_PR         CREATE_PR"
        "AISHORE_ISOLATION         ISOLATION_MODE"
        "AISHORE_NOTIFY            NOTIFY_SYSTEM"
    )
    local _env_name _target_var
    for _entry in "${_env_map[@]}"; do
        read -r _env_name _target_var <<< "$_entry"
        local _val="${!_env_name:-}"
        [[ -n "$_val" ]] && printf -v "$_target_var" '%s' "$_val"
    done

    # AISHORE_BACKLOG_FILES: comma-separated list overrides config/default
    if [[ -n "${AISHORE_BACKLOG_FILES:-}" ]]; then
        BACKLOG_FILES=()
        local _bf_entry
        IFS=',' read -ra _bf_parts <<< "$AISHORE_BACKLOG_FILES"
        for _bf_entry in "${_bf_parts[@]}"; do
            _bf_entry=$(printf '%s' "$_bf_entry" | xargs)  # trim whitespace
            [[ -n "$_bf_entry" ]] && BACKLOG_FILES+=("$_bf_entry")
        done
    fi

    return 0
}

# Validate that declared backlog files exist; warn on missing, don't abort
_validate_backlog_files() {
    local f
    for f in "${BACKLOG_FILES[@]}"; do
        if [[ ! -f "$BACKLOG_DIR/$f" ]]; then
            log_warning "Declared backlog file not found: $BACKLOG_DIR/$f"
        fi
    done
}

