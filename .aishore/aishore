send_notification() {
    local status="$1"
    local item_id="$2"
    if [[ -n "$NOTIFY_CMD" ]]; then
        if ! bash -c "$NOTIFY_CMD" -- "$status" "$item_id" 2>/dev/null; then
            log_warning "Notification command failed (exit $?) — sprint outcome unaffected"
        fi
    fi
}

send_session_notification() {
    local message="$1"
    local is_failure="${2:-false}"

    # Terminal bell — always fires, no config needed
    tput bel 2>/dev/null || printf '\a'

    # System notification — opt-in via notifications.system / AISHORE_NOTIFY
    if [[ "$NOTIFY_SYSTEM" == "true" ]]; then
        local title="aishore"
        if [[ "$(uname -s)" == "Darwin" ]]; then
            osascript -e "display notification \"${message//\"/\\\"}\" with title \"$title\"" 2>/dev/null || true
        elif command -v notify-send &>/dev/null; then
            local urgency="normal"
            [[ "$is_failure" == "true" ]] && urgency="critical"
            notify-send -u "$urgency" "$title" "$message" 2>/dev/null || true
        fi
    fi
}

# ============================================================================
# ITEM SELECTION
# ============================================================================

pick_item() {
    local specific_id="${1:-}"
    local skip_ids="${2:-}"
    local cat_filter="${3:-}"
    local item_json
    local source_file="$STATUS_DIR/.item_source"

    if [[ -n "$specific_id" ]]; then
        # Pick specific item by ID
        local backlog
        backlog=$(resolve_backlog_file "$specific_id") || {
            log_error "Item not found: $specific_id — run 'backlog list' to see valid IDs"
            return 1
        }
        local full_item
        full_item=$(find_item "$specific_id") || return 1

        # Project to sprint fields
        item_json=$(printf '%s\n' "$full_item" | jq "$ITEM_PROJECTION")

        # Extract all needed scalar fields from full_item in one jq pass
        local item_intent item_status deps_json item_category
        IFS=$'\t' read -r item_intent item_status deps_json item_category < <(
            printf '%s\n' "$full_item" | jq -r '[(.intent // ""), (.status // "todo"), (.dependsOn // null | tojson), (.category // "")] | @tsv'
        )
        [[ "$deps_json" == "null" ]] && deps_json=""

        # Enforce category filter — reject if item does not match
        if [[ -n "$cat_filter" && "$item_category" != "$cat_filter" ]]; then
            log_error "Item $specific_id category '${item_category:-<none>}' does not match --category '$cat_filter'"
            return 1
        fi

        # Enforce commander's intent — no intent, no sprint
        if [[ -z "$item_intent" ]]; then
            log_error "Item $specific_id has no intent — set one with: .aishore/aishore backlog edit $specific_id --intent \"...\""
            log_error "Commander's intent defines what must be true when done. No intent, no sprint."
            return 1
        elif [[ ${#item_intent} -lt 20 ]]; then
            log_error "Item $specific_id intent is too short — must be a clear directive, not a label"
            log_error "Current: \"$item_intent\""
            return 1
        fi

        if [[ "$item_status" == "done" ]]; then
            log_warning "Item $specific_id is already completed — re-running"
        fi
        # Check for unmet dependencies
        if [[ -n "$deps_json" && "$deps_json" != "null" ]]; then
            local all_done_ids
            all_done_ids=$(collect_done_ids)
            local unmet
            unmet=$(printf '%s\n' "$deps_json" | jq -r --argjson done_ids "$all_done_ids" '.[] | select(. as $dep | $done_ids | index($dep) == null)' 2>/dev/null)
            if [[ -n "$unmet" ]]; then
                log_warning "Item $specific_id has unmet dependencies: $(printf '%s\n' "$unmet" | tr '\n' ', ' | sed 's/,$//')"
            fi
        fi
        printf '%s\n' "$backlog" > "$source_file"
        printf '%s\n' "$item_json"
        return 0
    fi

    # Build skip list as JSON array for jq
    local skip_json="[]"
    if [[ -n "$skip_ids" ]]; then
        skip_json=$(printf '%s\n' "$skip_ids" | tr ',' '\n' | jq -R . | jq -s .)
    fi

    # Build list of done item IDs from both backlogs for dependency checking
    local done_ids_json
    done_ids_json=$(collect_done_ids)

    # Warn about self-referencing dependencies
    _warn_self_refs() {
        local bf="$1"
        local self_refs
        self_refs=$(jq -r '.items[] | select(.dependsOn != null) | select(.id as $self | .dependsOn | index($self) != null) | .id' "$BACKLOG_DIR/$bf" 2>/dev/null || true)
        if [[ -n "$self_refs" ]]; then
            while IFS= read -r sid; do
                log_warning "Item $sid has self-referencing dependency — skipping in auto-pick"
            done <<< "$self_refs"
        fi
    }
    map_backlog_files _warn_self_refs

    # Auto-pick: highest priority ready item across ALL declared backlog files
    local all_candidates="[]"
    _collect_candidates() {
        local backlog="$1"
        [[ -f "$BACKLOG_DIR/$backlog" ]] || return 0
        local candidates
        candidates=$(jq -r --argjson skip "$skip_json" --argjson done_ids "$done_ids_json" --arg src "$backlog" --arg catf "$cat_filter" '
            '"$PICKABLE_ITEMS_FILTER"' |
            [.[] | select($catf == "" or (.category // "") == $catf) | '"$ITEM_PROJECTION"' + {_source: $src}]
        ' "$BACKLOG_DIR/$backlog" 2>/dev/null || echo "[]")
        all_candidates=$(printf '%s\n%s\n' "$all_candidates" "$candidates" | jq -s 'add')
    }
    map_backlog_files _collect_candidates

    # Pick highest priority across all files
    local best
    best=$(printf '%s\n' "$all_candidates" | jq -r '
        sort_by(if .priority == "must" then 0 elif .priority == "should" then 1 elif .priority == "could" then 2 else 3 end) |
        first // empty
    ' 2>/dev/null)

    if [[ -n "$best" && "$best" != "null" ]]; then
        local best_source
        best_source=$(printf '%s\n' "$best" | jq -r '._source')
        item_json=$(printf '%s\n' "$best" | jq 'del(._source)')
        printf '%s\n' "$best_source" > "$source_file"
        printf '%s\n' "$item_json"
        return 0
    fi

    # Callers provide context-appropriate messages (auto-mode: drained; manual: no ready items)
    return 1
}

get_item_source() {
    local source_file="$STATUS_DIR/.item_source"
    [[ -f "$source_file" ]] && cat "$source_file" || echo ""
}

# ============================================================================
# BACKLOG HELPERS
# ============================================================================

# Core iterator: call callback(filename, ...) for each backlog file.
# Callback receives the short filename (e.g. "backlog.json"), not the full path.
map_backlog_files() {
    local _mbf_cb="$1"; shift
    local _mbf_f
    for _mbf_f in "${BACKLOG_FILES[@]}"; do
        "$_mbf_cb" "$_mbf_f" "$@"
    done
}

# Search iterator: call callback(filename, ...) for each backlog file,
# stop and return 0 on the first callback that succeeds (returns 0).
# Returns 1 if no callback succeeds.
find_first_backlog() {
    local _ffb_cb="$1"; shift
    local _ffb_f
    for _ffb_f in "${BACKLOG_FILES[@]}"; do
        if "$_ffb_cb" "$_ffb_f" "$@"; then
            return 0
        fi
    done
    return 1
}

# Copy each backlog file into dest_dir (for snapshot/backup).
snapshot_backlog_files() {
    local dest="$1"
    _sbf_copy() { [[ -f "$BACKLOG_DIR/$1" ]] && cp "$BACKLOG_DIR/$1" "$dest/$1" || true; }
    map_backlog_files _sbf_copy
}

# Restore backlog files from a snapshot directory.
restore_backlog_files() {
    local src="$1"
    _rbf_copy() { [[ -f "$src/$1" ]] && cp "$src/$1" "$BACKLOG_DIR/$1" || true; }
    map_backlog_files _rbf_copy
}

# Sum a per-file count function across all backlog files.
# Usage: sum_backlog_count count_func  (count_func receives full path)
sum_backlog_count() {
    local _sbc_func="$1" _sbc_total=0
    _sbc_add() {
        [[ -f "$BACKLOG_DIR/$1" ]] && _sbc_total=$((_sbc_total + $("$_sbc_func" "$BACKLOG_DIR/$1")))
    }
    map_backlog_files _sbc_add
    printf '%s\n' "$_sbc_total"
}

resolve_backlog_file() {
    local id="$1"
    local expected=""
    case "$id" in
        FEAT-*) expected="backlog.json" ;;
        BUG-*)  expected="bugs.json" ;;
    esac
    # Check expected file first if prefix matched
    if [[ -n "$expected" ]] && [[ -f "$BACKLOG_DIR/$expected" ]] && jq -e --arg id "$id" '.items[] | select(.id == $id)' "$BACKLOG_DIR/$expected" &>/dev/null; then
        printf '%s\n' "$expected"
        return 0
    fi
    # Fall through: search all files
    _try_resolve() {
        local f="$1" id="$2"
        [[ "$f" == "$expected" ]] && return 1
        if [[ -f "$BACKLOG_DIR/$f" ]] && jq -e --arg id "$id" '.items[] | select(.id == $id)' "$BACKLOG_DIR/$f" &>/dev/null; then
            printf '%s\n' "$f"
            return 0
        fi
        return 1
    }
    if find_first_backlog _try_resolve "$id"; then
        return 0
    fi
    log_error "Item not found in any backlog: $id"
    return 1
}

find_item() {
    local id="$1"
    local file
    file=$(resolve_backlog_file "$id") || return 1
    local item
    item=$(jq -e --arg id "$id" '.items[] | select(.id == $id)' "$BACKLOG_DIR/$file" 2>/dev/null) || {
        log_error "Item not found: $id"
        return 1
    }
    printf '%s\n' "$item"
}

check_readiness_gates() {
    local item_id="$1"
    local item
    item=$(find_item "$item_id") || return 1
    local warnings=""
    local has_warning=false

    # Extract all gate-check fields from item in one jq pass
    local title item_intent step_count ac_count short_steps deps
    IFS=$'\t' read -r title item_intent step_count ac_count short_steps < <(
        printf '%s\n' "$item" | jq -r '[
            (.title // ""),
            (.intent // ""),
            ([.steps // [] | .[]] | length | tostring),
            ([.acceptanceCriteria // [] | .[]] | length | tostring),
            ([.steps // [] | .[] | select(length <= 10)] | length | tostring)
        ] | @tsv'
    )
    deps=$(printf '%s\n' "$item" | jq -r '.dependsOn // [] | .[]' 2>/dev/null)

    # Check title non-empty
    if [[ -z "$title" ]]; then
        warnings="${warnings}  - Title is empty\n"
        has_warning=true
    fi

    # Check intent is present and substantive
    if [[ -z "$item_intent" ]]; then
        warnings="${warnings}  - No intent defined (the commander's intent — what must be true when this is done)\n"
        has_warning=true
    elif [[ ${#item_intent} -lt 20 ]]; then
        warnings="${warnings}  - Intent is too short (<20 chars) — must be a clear directive, not a label\n"
        has_warning=true
    fi

    # Check at least 1 step
    if [[ "$step_count" -lt 1 ]]; then
        warnings="${warnings}  - No implementation steps defined\n"
        has_warning=true
    fi

    # Check at least 1 acceptance criterion
    if [[ "$ac_count" -lt 1 ]]; then
        warnings="${warnings}  - No acceptance criteria defined\n"
        has_warning=true
    fi

    # Check no steps <= 10 chars
    if [[ "$short_steps" -gt 0 ]]; then
        warnings="${warnings}  - $short_steps step(s) are too short (<=10 chars)\n"
        has_warning=true
    fi

    # Check for unmet dependencies
    if [[ -n "$deps" ]]; then
        while IFS= read -r dep_id; do
            # Try to find the dependency in any backlog file
            local dep_item=""
            dep_item=$(find_item "$dep_id" 2>/dev/null) || true
            if [[ -z "$dep_item" ]]; then
                # Check if dependency was completed and archived (cleaned items)
                local archived=""
                if [[ -f "$ARCHIVE_DIR/sprints.jsonl" ]]; then
                    archived=$(jq -r --arg id "$dep_id" 'select(.itemId == $id) | .itemId' "$ARCHIVE_DIR/sprints.jsonl" 2>/dev/null | head -1)
                fi
                if [[ -z "$archived" ]]; then
                    warnings="${warnings}  - Dependency ${dep_id}: not found in any backlog\n"
                    has_warning=true
                fi
            else
                local dep_status
                dep_status=$(printf '%s\n' "$dep_item" | jq -r '.status // "todo"')
                if [[ "$dep_status" != "done" ]]; then
                    warnings="${warnings}  - Dependency ${dep_id}: status is '${dep_status}'\n"
                    has_warning=true
                fi
            fi
        done <<< "$deps"
    fi

    [[ -n "$warnings" ]] && printf '%s\n' "$warnings"
    if [[ "$has_warning" == "true" ]]; then
        log_error "Readiness gate check failed for $item_id"
        return 1
    fi
    return 0
}

# Advisory complexity hints — not a gate, just informational warnings
check_complexity_hints() {
    local item_id="$1"
    local item
    item=$(find_item "$item_id") || return 0
    local step_count has_scope
    IFS=$'\t' read -r step_count has_scope < <(
        printf '%s\n' "$item" | jq -r '[
            ([.steps // [] | .[]] | length | tostring),
            ([.scope // [] | .[]] | length | tostring)
        ] | @tsv'
    )
    local hints=""
    if [[ "$step_count" -lt 3 && "$step_count" -gt 0 ]]; then
        hints="${hints}    • Only $step_count step(s) — consider breaking the work into 3+ concrete steps\n"
    fi
    if [[ "$has_scope" -eq 0 ]]; then
        hints="${hints}    • No scope defined — add file path globs to constrain where changes land\n"
    fi
    if [[ -n "$hints" ]]; then
        printf '  - Item may be under-specified (advisory):\n%b\n' "$hints"
        return 1
    fi
    return 0
}

next_id() {
    local prefix="$1"
    local max=0
    # Check active backlog files
    _next_id_max() {
        local f="$1"
        [[ -f "$BACKLOG_DIR/$f" ]] || return 0
        local file_max
        file_max=$(jq -r --arg pfx "$prefix-" '[.items[].id | select(startswith($pfx)) | ltrimstr($pfx) | select(test("^[0-9]+$")) | tonumber] | max // 0' "$BACKLOG_DIR/$f" 2>/dev/null || echo 0)
        [[ "$file_max" -gt "$max" ]] && max="$file_max"
    }
    map_backlog_files _next_id_max
    # Check archive to prevent ID reuse after items are completed/removed
    local archive_file="$BACKLOG_DIR/archive/sprints.jsonl"
    if [[ -f "$archive_file" ]]; then
        local archive_max
        archive_max=$(jq -n -r --arg pfx "$prefix-" '[inputs | .itemId | select(startswith($pfx)) | ltrimstr($pfx) | select(test("^[0-9]+$")) | tonumber] | max // empty' "$archive_file" 2>/dev/null)
        [[ -n "$archive_max" && "$archive_max" -gt "$max" ]] && max="$archive_max"
    fi
    printf "%s-%03d" "$prefix" "$((max + 1))"
}

validate_priority() {
    local p="$1"
    case "$p" in
        must|should|could|future) return 0 ;;
        *) log_error "Invalid priority: $p (must be: must, should, could, future)"; return 1 ;;
    esac
}

validate_status() {
    local s="$1"
    case "$s" in
        todo|in-progress|done) return 0 ;;
        *) log_error "Invalid status: $s (must be: todo, in-progress, done)"; return 1 ;;
    esac
}

count_items() {
    local file="$1"
    jq '.items | length' "$file" 2>/dev/null || echo 0
}

count_by_status() {
    local file="$1" status="$2"
    jq --arg s "$status" '[.items[] | select((.status // "todo") == $s)] | length' "$file" 2>/dev/null || echo 0
}

count_ready_items() {
    local file="$1"
    jq '[.items[] | select(.readyForSprint == true and (.passes == false or .passes == null)) | select(.intent != null and .intent != "" and (.intent | length) >= 20)] | length' "$file" 2>/dev/null || echo 0
}

list_ready_items() {
    local file="$1"
    jq -r '.items[] | select(.readyForSprint == true and (.passes == false or .passes == null)) | select(.intent != null and .intent != "" and (.intent | length) >= 20) | "  \(.id): \(.title)"' "$file" 2>/dev/null
}

# List all auto-pickable item IDs in priority order (same filter as pick_item but returns all)
# Args: [skip_ids] [priority_filter] — priority_filter is space-separated list (e.g. "must should")
list_pickable_ids() {
    local skip_ids="${1:-}"
    local priority_filter="${2:-}"
    local cat_filter="${3:-}"
    local skip_json="[]"
    if [[ -n "$skip_ids" ]]; then
        skip_json=$(printf '%s\n' "$skip_ids" | tr ',' '\n' | jq -R . | jq -s .)
    fi
    local prio_json="[]"
    if [[ -n "$priority_filter" ]]; then
        # shellcheck disable=SC2086
        prio_json=$(printf '%s\n' $priority_filter | jq -R . | jq -s .)
    fi
    local done_ids_json
    done_ids_json=$(collect_done_ids)
    local _lpi_tmp
    _lpi_tmp="$(ensure_tmpdir)/pickable_ids.txt"
    : > "$_lpi_tmp"
    _list_pickable_one() {
        local backlog="$1"
        jq -r --argjson skip "$skip_json" --argjson done_ids "$done_ids_json" --argjson prios "$prio_json" --arg catf "$cat_filter" '
            '"$PICKABLE_ITEMS_FILTER"' |
            [.[] | select($catf == "" or (.category // "") == $catf)] |
            [.[] | select(($prios | length) == 0 or (.priority // "should") as $p | $prios | index($p) != null)] |
            .[] | (if .priority == "must" then 0 elif .priority == "should" then 1 elif .priority == "could" then 2 else 3 end | tostring) + "\t" + .id
        ' "$BACKLOG_DIR/$backlog" 2>/dev/null >> "$_lpi_tmp" || true
    }
    map_backlog_files _list_pickable_one
    sort -t$'\t' -k1,1n -s "$_lpi_tmp" | cut -f2
}

collect_done_ids() {
    local done_ids="[]"
    _collect_done_one() {
        local f="$1"
        [[ -f "$BACKLOG_DIR/$f" ]] || return 0
        local ids
        ids=$(jq '[.items[] | select(.status == "done") | .id]' "$BACKLOG_DIR/$f" 2>/dev/null || echo "[]")
        done_ids=$(printf '%s %s\n' "$done_ids" "$ids" | jq -s 'add | unique')
    }
    map_backlog_files _collect_done_one
    # Also include archived sprint item IDs (completed items removed via 'clean')
    local archive_file="$ARCHIVE_DIR/sprints.jsonl"
    if [[ -f "$archive_file" ]] && [[ -s "$archive_file" ]]; then
        local archived_ids
        archived_ids=$(jq -r '.itemId // empty' "$archive_file" 2>/dev/null | jq -R . | jq -s '.' 2>/dev/null || echo "[]")
        done_ids=$(printf '%s %s\n' "$done_ids" "$archived_ids" | jq -s 'add | unique')
    fi
    printf '%s\n' "$done_ids"
}

update_item() {
    local file="$1" id="$2" jq_expr="$3"
    shift 3
    local tmp
    tmp="$(ensure_tmpdir)/update_item.json"
    # remaining args are --arg pairs for jq
    # shellcheck disable=SC2086
    jq --arg id "$id" "$@" \
        "(.items[] | select(.id == \$id)) |= (. $jq_expr)" \
        "$BACKLOG_DIR/$file" > "$tmp" || {
        log_error "Failed to update item $id in $file"
        rm -f "$tmp"
        return 1
    }
    mv "$tmp" "$BACKLOG_DIR/$file"
}

_build_ac_json() {
    # Convert ac_entries array (passed as args) to a JSON array string.
    # Each entry is already a JSON value (quoted string or {text,verify} object).
    printf '%s\n' "$@" | jq -s .
}

_append_array_field() {
    # Append values from a bash array to a jq array field.
    # Usage: _append_array_field <field> <jq_var> <val1> [val2...]
    # Populates: jq_updates string and updates array (both must be declared in caller).
    local field="$1" jqvar="$2"
    shift 2
    local arr_json
    arr_json=$(printf '%s\n' "$@" | jq -R . | jq -s .)
    jq_updates="$jq_updates | .$field = ((.$field // []) + \$$jqvar)"
    updates+=("--argjson" "$jqvar" "$arr_json")
}

add_item() {
    local file="$1"
    shift
    # remaining args are --arg/--argjson pairs and the jq expression
    local tmp
    tmp="$(ensure_tmpdir)/add_item.json"
    jq "$@" "$BACKLOG_DIR/$file" > "$tmp" || {
        log_error "Failed to add item to $file"
        rm -f "$tmp"
        return 1
    }
    mv "$tmp" "$BACKLOG_DIR/$file"
}

remove_item() {
    local file="$1" id="$2"
    local tmp
    tmp="$(ensure_tmpdir)/remove_item.json"
    jq --arg id "$id" '.items |= map(select(.id != $id))' "$BACKLOG_DIR/$file" > "$tmp" || {
        log_error "Failed to remove item $id from $file"
        rm -f "$tmp"
        return 1
    }
    mv "$tmp" "$BACKLOG_DIR/$file"
}

remove_items_by_status() {
    local file="$1" status="$2"
    local tmp
    tmp="$(ensure_tmpdir)/remove_by_status.json"
    jq --arg s "$status" '.items |= map(select((.status // "todo") != $s))' "$BACKLOG_DIR/$file" > "$tmp" || {
        log_error "Failed to remove $status items from $file"
        rm -f "$tmp"
        return 1
    }
    mv "$tmp" "$BACKLOG_DIR/$file"
}

# ============================================================================
# SPRINT STATE
# ============================================================================

create_sprint() {
    local item_json="$1"
    local source="$2"
    local now
    now=$(portable_date_iso)

    local tmp_sprint
    tmp_sprint="$(ensure_tmpdir)/sprint_create.json"
    jq -n \
        --arg sprintId "sprint-$(date +%s)" \
        --arg startedAt "$now" \
        --arg source "$source" \
        --argjson item "$item_json" \
        '{
            sprintId: $sprintId,
            startedAt: $startedAt,
            status: "in_progress",
            item: {
                id: $item.id,
                title: ($item.title // $item.description),
                intent: ($item.intent // null),
                description: ($item.description // null),
                sourceBacklog: $source,
                steps: ($item.steps // []),
                acceptanceCriteria: ($item.acceptanceCriteria // []),
                scope: ($item.scope // []),
                startedAt: $startedAt
            }
        }' > "$tmp_sprint"
    mv "$tmp_sprint" "$BACKLOG_DIR/sprint.json"

    ITEM_ID=$(jq -r '.item.id' "$BACKLOG_DIR/sprint.json")
    log_info "Sprint created: $ITEM_ID - $(jq -r '.item.title' "$BACKLOG_DIR/sprint.json")"
}

mark_complete() {
    local item_id="$1"
    local source="$2"
    local attempts="${3:-1}"
    local now
    now=$(portable_date_iso)

    [[ -z "$source" ]] && { log_error "Cannot mark complete: source backlog is empty"; return 1; }

    # Update source backlog
    if ! update_item "$source" "$item_id" \
        '| . + {passes: true, status: "done", readyForSprint: false, completedAt: $ts}' \
        --arg ts "$now"; then
        log_error "Failed to update $source"
        return 1
    fi

    # Update sprint.json
    local tmp_sprint
    tmp_sprint="$(ensure_tmpdir)/sprint_update.json"
    if jq --arg ts "$now" --argjson attempts "$attempts" '.status = "completed" | .completedAt = $ts | .attempts = $attempts | .item.status = "passed" | .item.completedAt = $ts' \
        "$BACKLOG_DIR/sprint.json" > "$tmp_sprint" 2>/dev/null; then
        mv "$tmp_sprint" "$BACKLOG_DIR/sprint.json"
    else
        rm -f "$tmp_sprint"
        log_warning "Failed to update sprint.json status (item already marked complete in $source)"
    fi

    # Append enriched record to archive (non-fatal — primary state is already consistent)
    local sprint_id
    sprint_id=$(jq -r '.sprintId' "$BACKLOG_DIR/sprint.json" 2>/dev/null || echo "unknown")

    # Git diff stats
    local files_changed=0 lines_added=0 lines_removed=0
    local diffstat
    local diff_base="${AISHORE_BASE_BRANCH:-}"
    if [[ -z "$diff_base" ]]; then
        diff_base="HEAD~1"
    fi
    diffstat=$(git diff --shortstat "$diff_base" HEAD 2>/dev/null || true)
    if [[ -n "$diffstat" ]]; then
        files_changed=$(printf '%s\n' "$diffstat" | sed -n 's/.*\([0-9][0-9]*\) file.*/\1/p')
        lines_added=$(printf '%s\n' "$diffstat" | sed -n 's/.*\([0-9][0-9]*\) insertion.*/\1/p')
        lines_removed=$(printf '%s\n' "$diffstat" | sed -n 's/.*\([0-9][0-9]*\) deletion.*/\1/p')
    fi
    files_changed="${files_changed:-0}"
    lines_added="${lines_added:-0}"
    lines_removed="${lines_removed:-0}"

    # Duration from sprint start
    local duration=0
    local started_at
    started_at=$(jq -r '.startedAt // ""' "$BACKLOG_DIR/sprint.json" 2>/dev/null || true)
    if [[ -n "$started_at" ]]; then
        local start_epoch
        start_epoch=$(portable_date_epoch "$started_at")
        [[ "$start_epoch" -gt 0 ]] && duration=$(( $(date +%s) - start_epoch ))
    fi

    # Priority, category, and title from source backlog item (single jq call)
    local item_priority="" item_category="" item_title=""
    if [[ -n "$source" && -f "$BACKLOG_DIR/$source" ]]; then
        local pc_json
        pc_json=$(jq -r --arg id "$item_id" '.items[] | select(.id == $id) | [(.priority // ""), (.category // ""), (.title // "")] | @tsv' "$BACKLOG_DIR/$source" 2>/dev/null || true)
        if [[ -n "$pc_json" ]]; then
            item_priority=$(printf '%s' "$pc_json" | cut -f1)
            item_category=$(printf '%s' "$pc_json" | cut -f2)
            item_title=$(printf '%s' "$pc_json" | cut -f3)
        fi
    fi

    if ! jq -cn \
        --arg date "$(date +%Y-%m-%d)" \
        --arg sid "$sprint_id" \
        --arg iid "$item_id" \
        --argjson attempts "$attempts" \
        --argjson filesChanged "${files_changed}" \
        --argjson linesAdded "${lines_added}" \
        --argjson linesRemoved "${lines_removed}" \
        --argjson duration "$duration" \
        --arg priority "$item_priority" \
        --arg category "$item_category" \
        --arg title "$item_title" \
        '{date: $date, sprintId: $sid, itemId: $iid, status: "complete", attempts: $attempts, filesChanged: $filesChanged, linesAdded: $linesAdded, linesRemoved: $linesRemoved, duration: $duration, priority: (if $priority == "" then null else $priority end), category: (if $category == "" then null else $category end), title: (if $title == "" then null else $title end)}' \
        >> "$ARCHIVE_DIR/sprints.jsonl" 2>/dev/null; then
        log_warning "Failed to append to archive — sprint data is still consistent"
    fi
}

reset_sprint() {
    local tmp
    tmp="$(ensure_tmpdir)/sprint_reset.json"
    printf '%s\n' '{"sprintId": null, "status": "idle", "item": null}' > "$tmp"
    mv "$tmp" "$BACKLOG_DIR/sprint.json"
}

# ============================================================================
# AGENT EXECUTION
# ============================================================================

# Core process management: launch claude agent and wait for result.json or timeout.
# Args: agent_label model allowed_tools output_format prompt
#   agent_label   - name for logging
#   model         - model to use
#   allowed_tools - comma-separated tool list
#   output_format - "text" or "stream-json" (use "text" for --print capture)
#   prompt        - full prompt string (including context @-files)
# Optional: set AGENT_OUTPUT_FILE before calling to capture --print output to a file.
# Optional: set GROOM_MONITOR=true to track backlog changes during the poll loop.

# Helper: portable file hash for change detection (not cryptographic)
_file_hash() {
    if command -v sha256sum &>/dev/null; then
        sha256sum "$1" | cut -d' ' -f1
    elif command -v shasum &>/dev/null; then
        shasum -a 256 "$1" | cut -d' ' -f1
    else
        cksum "$1" | cut -d' ' -f1
    fi
}

# Helper: detect and report backlog file changes during grooming
_check_groom_progress() {
    local label="$1"
    local changed=false

    local _gp_f
    for _gp_f in "${BACKLOG_FILES[@]}"; do
        if [[ -f "$BACKLOG_DIR/$_gp_f" ]]; then
            local cur_hash
            cur_hash=$(_file_hash "$BACKLOG_DIR/$_gp_f")
            local hash_var
            hash_var="_groom_hash_$(printf '%s' "$_gp_f" | tr -c 'a-zA-Z0-9' '_')"
            local prev_hash="${!hash_var:-}"
            if [[ "$cur_hash" != "$prev_hash" ]]; then
                printf -v "$hash_var" '%s' "$cur_hash"
                changed=true
                local ready total
                ready=$(count_ready_items "$BACKLOG_DIR/$_gp_f")
                total=$(count_items "$BACKLOG_DIR/$_gp_f")
                log_agent "$label" "$_gp_f updated — $total items ($ready ready)"
            fi
        fi
    done

    if [[ "$changed" != "true" && $((elapsed % 30)) -eq 0 ]]; then
        log_agent "$label" "Working... (${elapsed}s elapsed)"
    fi
}

run_agent_process() {
    local agent_label="$1"
    local model="$2"
    local allowed_tools="$3"
    local output_format="$4"
    local prompt="$5"

    log_agent "$agent_label" "Starting (model: $model, timeout: ${AGENT_TIMEOUT}s)"
    local start_time
    start_time=$(date +%s)

    # Always capture agent output to a per-run log file for diagnostics
    local agent_log
    agent_log="$LOGS_DIR/${agent_label}-$(date +%Y%m%dT%H%M%S).log"
    LAST_AGENT_LOG="$agent_log"

    local has_setsid=false
    if command -v setsid &>/dev/null; then
        has_setsid=true
    fi

    local claude_args=(
        --model "$model"
        --permission-mode acceptEdits
        --allowedTools "$allowed_tools"
    )

    if [[ -n "${AGENT_OUTPUT_FILE:-}" ]]; then
        claude_args+=(--print)
        if [[ "$has_setsid" == true ]]; then
            setsid env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$AGENT_OUTPUT_FILE" 2>&1 &
        else
            env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$AGENT_OUTPUT_FILE" 2>&1 &
        fi
    else
        claude_args+=(--output-format "$output_format")
        if [[ "$has_setsid" == true ]]; then
            setsid env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$agent_log" 2>&1 &
        else
            env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$agent_log" 2>&1 &
        fi
    fi

    local agent_pid=$!
    local elapsed=0
    local got_result=false

    # Streaming: track how many lines of agent output we've already printed
    local _stream_lines_seen=0
    local _stream_log_file="${AGENT_OUTPUT_FILE:-$agent_log}"
    local _stream_enabled="$STREAMING_ENABLED"
    local _stream_max="$STREAMING_MAX_LINES"

    # Progress monitoring: track backlog file changes during grooming
    local monitor_backlogs="${GROOM_MONITOR:-false}"
    if [[ "$monitor_backlogs" == "true" ]]; then
        local _init_f
        for _init_f in "${BACKLOG_FILES[@]}"; do
            if [[ -f "$BACKLOG_DIR/$_init_f" ]]; then
                local hash_var
                hash_var="_groom_hash_$(printf '%s' "$_init_f" | tr -c 'a-zA-Z0-9' '_')"
                printf -v "$hash_var" '%s' "$(_file_hash "$BACKLOG_DIR/$_init_f")"
            fi
        done
    fi

    while [[ $elapsed -lt $AGENT_TIMEOUT ]]; do
        if ! kill -0 "$agent_pid" 2>/dev/null; then
            # Process exited — stream any remaining lines before breaking
            if [[ "$_stream_enabled" == "true" && -f "$_stream_log_file" ]]; then
                local _final_lines
                _final_lines=$(tail -n +"$((_stream_lines_seen + 1))" "$_stream_log_file" 2>/dev/null | head -n "$_stream_max") || true
                if [[ -n "$_final_lines" ]]; then
                    printf '%s\n' "$_final_lines"
                    _stream_lines_seen=$(wc -l < "$_stream_log_file" 2>/dev/null || echo "$_stream_lines_seen")
                fi
            fi
            break
        fi
        if [[ -f "$STATUS_DIR/result.json" ]]; then
            got_result=true
            sleep 2
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))

        # Stream new agent output lines (rate-limited)
        if [[ "$_stream_enabled" == "true" && -f "$_stream_log_file" ]]; then
            local _new_lines
            _new_lines=$(tail -n +"$((_stream_lines_seen + 1))" "$_stream_log_file" 2>/dev/null | head -n "$_stream_max") || true
            if [[ -n "$_new_lines" ]]; then
                printf '%s\n' "$_new_lines"
                local _printed
                _printed=$(printf '%s\n' "$_new_lines" | wc -l)
                _stream_lines_seen=$((_stream_lines_seen + _printed))
            fi
        fi

        # Check for backlog changes and report progress
        if [[ "$monitor_backlogs" == "true" && $((elapsed % 10)) -eq 0 ]]; then
            _check_groom_progress "$agent_label"
        elif [[ "$_stream_enabled" != "true" && $((elapsed % 30)) -eq 0 ]]; then
            log_agent "$agent_label" "Waiting for agent... (${elapsed}s elapsed)"
        fi
    done

    # Kill the process if it's still running
    if kill -0 "$agent_pid" 2>/dev/null; then
        if [[ "$got_result" != "true" ]]; then
            log_warning "Agent timed out after ${AGENT_TIMEOUT}s, killing..."
        fi
        if [[ "$has_setsid" == true ]]; then
            kill -TERM -- -"$agent_pid" 2>/dev/null || kill -TERM "$agent_pid" 2>/dev/null
            sleep 2
            kill -KILL -- -"$agent_pid" 2>/dev/null || true
        else
            kill -TERM "$agent_pid" 2>/dev/null || true
            sleep 2
            kill -KILL "$agent_pid" 2>/dev/null || true
        fi
    fi

    wait "$agent_pid" 2>/dev/null || true

    # Copy AGENT_OUTPUT_FILE to agent log if used (so LAST_AGENT_LOG is always valid)
    if [[ -n "${AGENT_OUTPUT_FILE:-}" && -f "$AGENT_OUTPUT_FILE" ]]; then
        cp "$AGENT_OUTPUT_FILE" "$agent_log" 2>/dev/null || true
    fi

    local duration
    duration=$(($(date +%s) - start_time))
    log_agent "$agent_label" "Completed in ${duration}s"

    append_log "$LOGS_DIR/agent-runs.log" \
        "$(portable_date_iso)|$agent_label|${AGENT_MODE:-unknown}|${duration}s|$model"
}

build_agent_prompt() {
    local agent_name="$1"
    local mode="$2"
    local extra_prompt="${3:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    # Read prompt file; strip populate section unless in populate mode
    local prompt_content
    if [[ "$agent_name" == "product-owner" && "$mode" != "populate" ]]; then
        prompt_content="$(sed '/^## Populate Mode/,$d' "$prompt_file" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')"
    else
        prompt_content="$(cat "$prompt_file")"
    fi

    # Build orchestrator injections
    local validate_hint=""
    if [[ "$agent_name" == "developer" ]]; then
        validate_hint="
## Commander's Intent
The \`intent\` field in sprint.json is a non-negotiable directive — what must be true when done. When the spec is unclear or steps seem wrong, intent is the order you follow."

        if [[ -n "$FIX_CMD" ]]; then
            validate_hint="$validate_hint

## Auto-Fix
After you finish, the orchestrator will automatically run \`$FIX_CMD\` to fix lint/formatting issues. Do not worry about auto-fixable style issues — focus on correctness and AC."
        fi

        if [[ "$MATURITY_ENABLED" == "true" ]]; then
            validate_hint="$validate_hint

## Maturity Protocol (MANDATORY — complete all phases)
**Phase 1 — Implement:** Write the code. Follow spec, match patterns.${VALIDATE_CMD:+ Run \`$VALIDATE_CMD\` and fix failures.}
**Phase 2 — Critique:** STOP coding. Re-read every changed file. Verify intent is fulfilled and each AC is provably met. Hunt bugs, edge cases, dead code, missing error handling. Fix everything found.
**Phase 3 — Harden:** Run validation${VALIDATE_CMD:+ (\`$VALIDATE_CMD\`)} again. Fix regressions. Re-verify all AC. Only then commit and signal done.
Output phase markers: \`═══ PHASE 2: CRITIQUE ═══\` / \`═══ PHASE 3: HARDEN ═══\`"
        elif [[ -n "$VALIDATE_CMD" ]]; then
            validate_hint="$validate_hint

## Validation
Run \`$VALIDATE_CMD\` after implementing. Fix failures before writing result.json."
        fi
    elif [[ "$agent_name" == "validator" ]]; then
        validate_hint=""
        if [[ -n "$VALIDATE_CMD" ]]; then
            validate_hint="
## Validation Command
The orchestrator runs \`$VALIDATE_CMD\` before you. If results are provided below, trust them — do not re-run the command."
        fi
    elif [[ "$agent_name" == "tech-lead" || "$agent_name" == "product-owner" ]]; then
        # CLI commands: shared preamble + role-specific examples
        local cli_role_lines
        if [[ "$agent_name" == "product-owner" ]]; then
            cli_role_lines=".aishore/aishore backlog add --type feat --title \"...\" --desc \"...\" --priority should
.aishore/aishore backlog edit <ID> --priority must --groomed-at --groomed-notes \"...\""
        else
            cli_role_lines=".aishore/aishore backlog add --type bug --title \"...\" --desc \"...\" --priority should
.aishore/aishore backlog edit <ID> --ready --groomed-at --groomed-notes \"...\"
.aishore/aishore backlog edit <ID> --priority must"
        fi
        validate_hint="
## CLI Commands

Use CLI commands to manage items — do NOT edit JSON directly:

\`\`\`bash
.aishore/aishore backlog list
.aishore/aishore backlog show <ID>
${cli_role_lines}
.aishore/aishore backlog rm <ID> --force
\`\`\`

## Commander's Intent
Every item should have an \`intent\` field — a non-negotiable directive stating what must be true when done. Use \`--intent \"...\"\` when adding/editing items. Write it like an order, not a description.

## Grooming Limits
- **Maximum items per session:** $GROOM_MAX_ITEMS — stop adding new items after this cap. Focus on the highest-value items first.
- **Minimum priority threshold:** $GROOM_MIN_PRIORITY — only add items at \`$GROOM_MIN_PRIORITY\` priority or higher. Skip lower-priority items (log them in your summary but do not add them).
- When you reach the cap or run out of items above the threshold, stop and signal completion. Do not generate busywork."
    fi

    local prompt
    prompt="$prompt_content
${extra_prompt:+
$extra_prompt}${validate_hint:+
$validate_hint}

## Mode
$mode
$(build_completion_contract)"
    printf '%s\n' "$prompt"
}

run_agent() {
    local agent_name="$1"
    local mode="$2"
    local model="${3:-$MODEL_PRIMARY}"
    local _ra_ctx_name="${4:-}"
    local output_file="${5:-}"
    local extra_prompt="${6:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    rm -f "$STATUS_DIR/result.json"

    local context_files
    if [[ -n "$_ra_ctx_name" ]]; then
        local -n _ra_ctx_ref="$_ra_ctx_name"
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context "${_ra_ctx_ref[@]}")
    else
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context "@$BACKLOG_DIR/sprint.json")
    fi

    # Derive permissions based on agent role and mode
    local agent_perms
    case "$agent_name" in
        developer)
            agent_perms="${CFG_PERMS_DEVELOPER:-$PERMS_DEVELOPER}" ;;
        validator)
            agent_perms="${CFG_PERMS_VALIDATOR:-$PERMS_VALIDATOR}" ;;
        architect)
            agent_perms="${CFG_PERMS_REVIEWER:-$PERMS_REVIEWER}" ;;
        tech-lead|product-owner)
            # Groom agents need full permissions to update backlog files
            agent_perms="${CFG_PERMS_DEVELOPER:-$PERMS_DEVELOPER}" ;;
        *)
            agent_perms="${CFG_PERMS_DEVELOPER:-$PERMS_DEVELOPER}" ;;
    esac

    local prompt
    prompt=$(build_agent_prompt "$agent_name" "$mode" "$extra_prompt")

    if [[ -n "$output_file" ]]; then
        AGENT_OUTPUT_FILE="$output_file" AGENT_MODE="$mode" run_agent_process "$agent_name" "$model" \
            "$agent_perms" "" \
            "$context_files
$prompt"
    else
        AGENT_MODE="$mode" run_agent_process "$agent_name" "$model" \
            "$agent_perms" "text" \
            "$context_files
$prompt"
    fi
}

show_failure_log_tail() {
    if [[ -n "$LAST_AGENT_LOG" && -f "$LAST_AGENT_LOG" ]]; then
        local line_count
        line_count=$(wc -l < "$LAST_AGENT_LOG" 2>/dev/null || echo 0)
        if [[ "$line_count" -gt 0 ]]; then
            echo ""
            echo -e "${RED}── Last 20 lines of agent log ──${NC}"
            tail -n 20 "$LAST_AGENT_LOG" 2>/dev/null || true
            echo -e "${RED}── End of log tail ──${NC}"
        fi
        log_info "Full agent log: $LAST_AGENT_LOG"
    fi
}

check_result() {
    if [[ ! -f "$STATUS_DIR/result.json" ]]; then
        log_error "No result file - agent may have crashed"
        show_failure_log_tail
        return 1
    fi

    local status
    # Support both simple format {"status":"pass"} and detailed format {"overall":"PASS"}
    status=$(jq -r '.status // .overall // "unknown"' "$STATUS_DIR/result.json" 2>/dev/null)
    # Normalize to lowercase so PASS/pass both match
    status=$(printf '%s\n' "$status" | tr '[:upper:]' '[:lower:]')

    if [[ "$status" == "pass" ]]; then
        local summary
        summary=$(jq -r '.summary // .checks // "completed"' "$STATUS_DIR/result.json")
        log_success "$summary"
        return 0
    else
        local reason
        reason=$(jq -r '.reason // "unknown error"' "$STATUS_DIR/result.json")
        if [[ "$reason" == "unknown error" ]]; then
            # Include actual file contents to aid debugging
            local raw_content
            raw_content=$(cat "$STATUS_DIR/result.json" 2>/dev/null || echo "(unreadable)")
            log_error "Unexpected result format: $raw_content"
        else
            log_error "$reason"
        fi
        show_failure_log_tail
        return 1
    fi
}

check_scope_violations() {
    local sprint_file="$BACKLOG_DIR/sprint.json"
    [[ ! -f "$sprint_file" ]] && return 0

    local scope_json
    scope_json=$(jq -r '.item.scope // empty' "$sprint_file" 2>/dev/null)
    [[ -z "$scope_json" || "$scope_json" == "null" || "$scope_json" == "[]" ]] && return 0

    # Read scope globs into array in one pass (also handles empty check)
    local -a globs=()
    while IFS= read -r glob; do
        globs+=("$glob")
    done < <(jq -r '.[]' <<< "$scope_json" 2>/dev/null)
    [[ ${#globs[@]} -eq 0 ]] && return 0

    # Get changed files against base branch (developer may have multiple commits)
    local base_branch="$AISHORE_BASE_BRANCH"
    [[ -z "$base_branch" ]] && return 0

    local changed_files
    changed_files=$(git diff --name-only "$base_branch"...HEAD 2>/dev/null || true)
    [[ -z "$changed_files" ]] && return 0

    local violations=""
    local violation_count=0
    while IFS= read -r file; do
        local in_scope=false
        for glob in "${globs[@]}"; do
            # Convert ** to * for bash pattern matching (simplistic but functional)
            local pattern="${glob//\*\*/*}"
            # shellcheck disable=SC2254,SC2053
            if [[ "$file" == $pattern ]]; then
                in_scope=true
                break
            fi
        done
        if [[ "$in_scope" != "true" ]]; then
            violations+="  - $file"$'\n'
            violation_count=$((violation_count + 1))
        fi
    done <<< "$changed_files"

    if [[ "$violation_count" -gt 0 ]]; then
        printf '%s\n%s' "$violation_count file(s) outside declared scope:" "$violations"
        if [[ "$SCOPE_MODE" == "strict" ]]; then
            log_error "Scope violation (strict mode): $violation_count file(s) outside scope"
            printf '%b\n' "$violations" >&2
            return 1
        else
            log_warning "Scope violation: $violation_count file(s) outside scope" >&2
            printf '%b\n' "$violations" >&2
            return 0
        fi
    fi
    return 0
}

run_ac_verification() {
    local sprint_file="$BACKLOG_DIR/sprint.json"
    [[ ! -f "$sprint_file" ]] && return 0

    local ac_json
    if ! ac_json=$(jq -r '.item.acceptanceCriteria // []' "$sprint_file" 2>&1); then
        log_error "Failed to parse acceptanceCriteria from sprint.json: $ac_json"
        return 1
    fi
    [[ -z "$ac_json" || "$ac_json" == "null" || "$ac_json" == "[]" ]] && return 0

    # Filter to objects with .verify field and get count in one pass
    local verifiable verify_count
    if ! verifiable=$(printf '%s\n' "$ac_json" | jq '[.[] | select(type == "object" and .verify != null)]' 2>&1); then
        log_error "Failed to parse AC verify fields: $verifiable"
        return 1
    fi
    verify_count=$(jq 'length' <<< "$verifiable" 2>/dev/null || echo 0)
    [[ "$verify_count" -eq 0 ]] && return 0

    log_info "Running $verify_count AC verification command(s)" >&2
    local all_passed=true
    local report=""
    local idx=0

    while IFS=$'\t' read -r ac_text ac_cmd; do
        idx=$((idx + 1))

        local ac_ok=true
        local ac_tmpfile
        ac_tmpfile="$(ensure_tmpdir)/ac_verify_${idx}.txt"
        run_validated_command "$ac_cmd" "$ac_tmpfile" || ac_ok=false
        local ac_output
        ac_output=$(truncate_output "$ac_tmpfile")
        rm -f "$ac_tmpfile"

        if [[ "$ac_ok" == "true" ]]; then
            report="${report}  PASS: ${ac_text}"$'\n'
            log_success "AC: $ac_text" >&2
        else
            report="${report}  FAIL: ${ac_text} (cmd: ${ac_cmd})"$'\n'"    Output: ${ac_output}"$'\n'
            log_error "AC: $ac_text"
            all_passed=false
        fi
    done < <(jq -r '.[] | [(.text // "unnamed"), .verify] | @tsv' <<< "$verifiable")

    [[ -n "$report" ]] && printf '%s\n' "$report"
    [[ "$all_passed" == "true" ]] && return 0 || return 1
}

